# ── Anthropic ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_claude_api_key_here
MODEL=claude-sonnet-4-6
MAX_TOKENS=4096

# ── Mock mode (no API credits needed) ──────────────────────────────
# Set to true to run the server and demo the UI without calling Claude.
# Visit http://localhost:3000 and click "Try Demo" on the profile screen,
# or hit GET /api/demo directly in the browser.
MOCK_MODE=false

# ── Rate limiting ───────────────────────────────────────────────────
# Format: N/period  e.g. "5/hour", "10/day", "1/minute"
RATE_LIMIT=3/hour

# ── Optional API key gate ───────────────────────────────────────────
# Leave blank to disable. When set, /api/analyze requires X-API-Key header.
API_SECRET_KEY=

# ── Database location / persistence ─────────────────────────────────
# Resolved at startup, first writable wins:
#   1. BF_DB_PATH                       (explicit override — set this to force a path)
#   2. RAILWAY_VOLUME_MOUNT_PATH        (auto-set by Railway when a volume is attached;
#                                        DB is stored at <mount>/analyses.db — survives redeploys)
#   3. backend/data/analyses.db         (local default)
#   4. /tmp/bf_analyses.db              (EPHEMERAL fallback — data lost on redeploy)
# On Railway: attach a volume (mount path e.g. /app/data) so analyses persist.
# The resolved path + tier is logged at startup ([imara.db] ...) and exposed at
# GET /api/admin/db-status. See DB_PERSISTENCE_RUNBOOK.md.
BF_DB_PATH=

# ── Error monitoring (Sentry) ───────────────────────────────────────
# Optional. Leave blank to disable (no-op). When set, unhandled backend
# exceptions are reported to Sentry. send_default_pii=False and request bodies
# are NEVER captured (POPIA-safe). Get the DSN from your Sentry project settings.
SENTRY_DSN=
# Performance tracing sample rate (0.0 = errors only, no perf spans). Keep 0.0 unless needed.
SENTRY_TRACES_SAMPLE_RATE=0.0
# Environment label shown in Sentry (defaults to RAILWAY_ENVIRONMENT or "production").
SENTRY_ENV=

# ── LLM observability (Langfuse) ────────────────────────────────────
# Optional. Leave blank to disable (no-op). When set, every Claude call exports
# METADATA ONLY — model, token counts, latency, estimated cost — grouped per
# analysis. No prompt or completion text is ever sent (privacy by construction),
# so confidential client financials never leave to Langfuse. Self-host Langfuse
# (set LANGFUSE_HOST) if you want full I/O capture later. Keys: Langfuse project settings.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com   # or your self-hosted URL
# TRACING_ENABLED=true   # force the export path on without Langfuse keys (debug/no-op)
